import pepita.*
import comidas.*
import niveles.*
import extras.*
import wollok.game.*
import direccion.*

program PepitaGame {
	const tick = game.tick(500, { muro.movete() }, false)

	game.title("Pepita")
	game.cellSize(50)    
	game.height(15)
	game.width(15)
	game.boardGround('fondo2.jpg')


 	game.addVisual(silvestre)
	game.addVisual(alpiste)
    game.addVisual(manzana)
	game.addVisual(nido)
	game.addVisual(muro)
	game.addVisual(pepita)
	
	nivel1.init()
	tick.start()
	game.start()
}